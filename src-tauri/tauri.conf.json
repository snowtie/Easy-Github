{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyGithub",
  "version": "2.2.0",
  "identifier": "com.easygithub.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EasyGithub",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/remove-electron-169.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2RjlBQjQxMTdEMDYwODgKUldTSVlOQVhRYXY1bHJEZU02K1NqN2lxc0RMUXJ6czhmMjJXSEtkcXR4UUVqTXlOK21oUyt2VVkK",
      "endpoints": [
        "https://github.com/snowtie/Easy-Github/releases/latest/download/latest.json"
      ]
    }
  }
}
